<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- Assistive Access: fill the whole screen instead of the default reduced
	     frame. Our UI uses adaptive SwiftUI containers (VStack/HStack/Spacer),
	     so it expands to use all available space at any size. -->
	<key>UISupportsFullScreenInAssistiveAccess</key>
	<true/>
</dict>
</plist>
